# --- Core ---
DATABASE_URL=postgres://aiwatch:aiwatch@localhost:5432/aiwatch
NODE_ENV=development
APP_TZ=Asia/Shanghai
UI_LOCALE=zh
CONTENT_LANG=zh
# Canonical public origin for absolute links in RSS and machine-readable outputs.
# Recommended in production; if missing, RSS falls back to the request origin.
PUBLIC_BASE_URL=
# Log verbosity for the src/log.ts seam: debug | info | warn | error.
# Defaults to debug in dev, info in production.
LOG_LEVEL=

# --- Production hardening (validated at boot by src/config/env.ts; warn in dev, fail in prod) ---
# Number of trusted proxies/CDNs in front of the app. Required in production so the deploy
# makes an explicit trust decision. clientIp() ignores X-Forwarded-For at 0 (direct expose);
# 1 = one trusted CDN/proxy that appends the real client as the rightmost XFF entry; etc.
TRUSTED_PROXY_HOPS=
# DB TLS (production only). Leave unset to require TLS with cert verification.
#   DATABASE_SSL=disable      -> no TLS (trusted private network / unix socket only)
#   DATABASE_SSL_NO_VERIFY=1  -> TLS on, accept self-signed (many managed Postgres)
#   DATABASE_SSL_CA=<pem>     -> pin a CA bundle
DATABASE_SSL=
DATABASE_SSL_NO_VERIFY=
DATABASE_SSL_CA=
# Set CSP_ENFORCE=1 in production so Content-Security-Policy blocks instead of only
# reporting. Use CSP_ENFORCE=0 only temporarily while validating a staging build.
CSP_ENFORCE=

# --- Auth (better-auth) ---
# Generate a strong random secret in production (>= 32 chars; never the placeholder below).
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000
# Optional Google OAuth for reader login. Add the redirect URI
# `${BETTER_AUTH_URL}/api/auth/callback/google` in Google Cloud.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional WeChat Website Application OAuth for reader login. Add the redirect URI
# `${BETTER_AUTH_URL}/api/auth/callback/wechat` in WeChat Open Platform.
WECHAT_CLIENT_ID=
WECHAT_CLIENT_SECRET=
# Email OTP delivery. In development, missing values print the OTP in server logs.
# In production, configure both so login codes are emailed.
AUTH_EMAIL_FROM=
RESEND_API_KEY=
# Reader-identity cookie HMAC secret (Slice 8). Anonymous reactions are signed with this.
# Required in production and must be distinct from BETTER_AUTH_SECRET (>= 32 chars).
# Development can leave this blank and use the local fallback.
READER_ID_SECRET=
# Salt for anonymous contributor fingerprints. Required in production (>= 16 chars);
# the dev default is predictable.
CONTRIBUTION_SALT=

# --- LLM providers ---
# Per-task routing references a provider; a missing key fails CLOSED for that route only.
# Production validates the configured light_judge/deep_extract provider key at boot. The
# default light/deep provider is DeepSeek, so set DEEPSEEK_API_KEY or override LLM_PROVIDER
# to another keyed provider.
# When a route has no key and LLM_STUB_FALLBACK != "1", posts the route would have judged
# are marked judge_failed (no event created). Set LLM_STUB_FALLBACK=1 ONLY in local dev/demo.
LLM_STUB_FALLBACK=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
QWEN_API_KEY=
QWEN_BASE_URL=
# OpenAI-compatible endpoint (Ollama / vLLM / LM Studio / SiliconFlow / OpenRouter / DashScope).
# Third-party proxies may substitute models, leak data, or bill opaquely — prefer official endpoints.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
# Override the news summarization / cold_judge route without editing code.
# Example provider: openai_compatible
LLM_NEWS_PROVIDER=
LLM_NEWS_MODEL=

# --- Source connectors (optional; fail closed when missing) ---
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Preferred RSSHub base URL, for example https://rsshub.app or your own instance. Required
# whenever enabled sources use connectorType=rsshub; docker-compose.prod.yml includes a
# local rsshub service, so production typically sets RSSHUB_BASE_URL=http://rsshub:1200.
RSSHUB_BASE_URL=
# Legacy alias kept for older local env files; RSSHUB_BASE_URL takes precedence.
RSSHUB_URL=
# X/Twitter auth token for the self-hosted RSSHub's /twitter/* routes (docker-compose.prod.yml
# passes it into the rsshub container). Without it those routes return 404/503 and every
# X source fails its crawl.
TWITTER_AUTH_TOKEN=
X_API_TOKEN=

# --- Budget guard (USD/month) ---
# spend_guard warns at 80%, fails closed paid connectors + non-critical LLM at 100%.
MAX_MONTHLY_LLM_USD=50
MAX_MONTHLY_X_API_USD=0
