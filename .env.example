# --- Core ---
DATABASE_URL=postgres://aiwatch:aiwatch@localhost:5432/aiwatch
NODE_ENV=development
APP_TZ=Asia/Shanghai
UI_LOCALE=zh
CONTENT_LANG=zh
# Log verbosity for the src/log.ts seam: debug | info | warn | error.
# Defaults to debug in dev, info in production.
LOG_LEVEL=

# --- Production hardening (validated at boot by src/config/env.ts; warn in dev, fail in prod) ---
# Number of trusted proxies/CDNs in front of the app. clientIp() reads this hop from the
# right of X-Forwarded-For. 0 = directly exposed (no proxy); 1 = one trusted CDN; etc.
TRUSTED_PROXY_HOPS=0
# DB TLS (production only). Leave unset to require TLS with cert verification.
#   DATABASE_SSL=disable      -> no TLS (trusted private network / unix socket only)
#   DATABASE_SSL_NO_VERIFY=1  -> TLS on, accept self-signed (many managed Postgres)
#   DATABASE_SSL_CA=<pem>     -> pin a CA bundle
DATABASE_SSL=
DATABASE_SSL_NO_VERIFY=
DATABASE_SSL_CA=
# Set CSP_ENFORCE=1 to switch the Content-Security-Policy from Report-Only to enforcing,
# AFTER validating the reader + /_admin render with no CSP violations.
CSP_ENFORCE=

# --- Auth (better-auth) ---
# Generate a strong random secret in production (>= 32 chars; never the placeholder below).
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000
# Reader-identity cookie HMAC secret (Slice 8). Anonymous reactions are signed with this.
# Falls back to BETTER_AUTH_SECRET when unset; set a distinct value (>= 32 chars) in
# production so rotating one secret doesn't invalidate the other.
READER_ID_SECRET=
# Salt for anonymous contributor fingerprints. Required in production (>= 16 chars);
# the dev default is predictable.
CONTRIBUTION_SALT=

# --- LLM providers ---
# Per-task routing references a provider; a missing key fails CLOSED for that route only.
# When a route has no key and LLM_STUB_FALLBACK != "1", posts the route would have judged
# are marked judge_failed (no event created). Set LLM_STUB_FALLBACK=1 ONLY in local dev/demo.
LLM_STUB_FALLBACK=
OPENAI_API_KEY=
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
QWEN_API_KEY=
QWEN_BASE_URL=
# OpenAI-compatible endpoint (Ollama / vLLM / LM Studio / SiliconFlow / OpenRouter / DashScope).
# Third-party proxies may substitute models, leak data, or bill opaquely — prefer official endpoints.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
# Override the news summarization / cold_judge route without editing code.
# Example provider: openai_compatible
LLM_NEWS_PROVIDER=
LLM_NEWS_MODEL=

# --- Source connectors (optional; fail closed when missing) ---
GITHUB_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Preferred RSSHub base URL, for example https://rsshub.app or your own instance.
RSSHUB_BASE_URL=
# Legacy alias kept for older local env files; RSSHUB_BASE_URL takes precedence.
RSSHUB_URL=
X_API_TOKEN=

# --- Budget guard (USD/month) ---
# spend_guard warns at 80%, fails closed paid connectors + non-critical LLM at 100%.
MAX_MONTHLY_LLM_USD=50
MAX_MONTHLY_X_API_USD=0
